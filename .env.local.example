# Sanity Studio / Client configuration
# Copy to .env.local and fill in values from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: read token for previews / draft content
SANITY_API_READ_TOKEN=

# Optional: WhatsApp / contact integration
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
NEXT_PUBLIC_CONTACT_EMAIL=events@maanevents.com
NEXT_PUBLIC_CONTACT_PHONE=+91 99999 99999
